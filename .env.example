# ===========================================
# DataGN Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in the values

# ===========================================
# Database
# ===========================================
DATABASE_URL="postgresql://datagn:datagn@localhost:5432/datagn"

# ===========================================
# Authentication
# ===========================================
# Required: Min 32 characters for AUTH_SECRET
AUTH_SECRET="your-secret-key-minimum-32-characters-long"
NEXTAUTH_URL="http://localhost:3000"

# ===========================================
# AI Service (Anthropic)
# ===========================================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-api03-your-key-here"

# ===========================================
# Storage (S3 / MinIO)
# ===========================================
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="datagn"
S3_REGION="us-east-1"

# ===========================================
# Redis (Queue & Cache)
# ===========================================
REDIS_URL="redis://localhost:6379"

# ===========================================
# Keycloak SSO (Optional)
# ===========================================
KEYCLOAK_ISSUER="http://localhost:8082/realms/datagn"
KEYCLOAK_CLIENT_ID="datagn-web"
KEYCLOAK_CLIENT_SECRET="your-keycloak-client-secret"
NEXT_PUBLIC_KEYCLOAK_URL="http://localhost:8082"

# ===========================================
# Stripe (Payments)
# ===========================================
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"

# ===========================================
# Email (Resend)
# ===========================================
RESEND_API_KEY="re_your-resend-api-key"
EMAIL_FROM="noreply@datagn.com"

# ===========================================
# Monitoring (Sentry)
# ===========================================
NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# ===========================================
# Application
# ===========================================
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="DataGN"

# ===========================================
# Feature Flags (Optional)
# ===========================================
ENABLE_AI_ANALYSIS="true"
ENABLE_EXPORT_PDF="true"
ENABLE_PUBLIC_SHARE="true"

# ===========================================
# Debug (Development Only)
# ===========================================
# DEBUG="datagn:*"
# LOG_LEVEL="debug"
