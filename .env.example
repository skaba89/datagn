# Variables d'environnement DataGN
# Copiez ce fichier : cp .env.example .env.local
# NE JAMAIS COMMITTER .env.local

# ─────────────────────────────────────────────────────────────────
# OBLIGATOIRE — Clé API Anthropic (Claude IA)
# SÉCURITÉ — Domaines CORS autorisés à appeler /api/*
# En local : laisser vide (localhost autorisé par défaut)
# En production : lister les domaines séparés par une virgule
# ─────────────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=https://app.datagn.com,https://datagn.com

# 🗄️ DATABASE (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:pass@localhost:5432/datagn"

# 🔑 AUTHENTICATION (NextAuth)
# Générer avec: openssl rand -base64 32
NEXTAUTH_SECRET="votre_secret_tres_long_ici"
NEXTAUTH_URL="http://localhost:3000"

# 🤖 AI (Anthropic)
ANTHROPIC_API_KEY="sk-ant-..."

# ─────────────────────────────────────────────────────────────────
# OPTIONNEL — URL de l'app (pour liens absolus, emails, etc.)
# ─────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL=https://app.datagn.com
