# ===========================================
# DataGN Environment Configuration - Development
# ===========================================

# ===========================================
# Database (SQLite for local dev)
# ===========================================
DATABASE_URL="file:./prisma/dev.db"

# ===========================================
# Authentication
# ===========================================
AUTH_SECRET="datagn-dev-secret-key-minimum-32-chars-for-testing"
NEXTAUTH_URL="http://localhost:3000"

# ===========================================
# Application
# ===========================================
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="DataGN"

# ===========================================
# AI Service (Optional - leave empty for demo)
# ===========================================
ANTHROPIC_API_KEY=""

# ===========================================
# Storage (Optional - local filesystem fallback)
# ===========================================
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="datagn"
S3_REGION="us-east-1"

# ===========================================
# Redis (Optional - disabled for local dev)
# ===========================================
REDIS_URL=""

# ===========================================
# Feature Flags
# ===========================================
ENABLE_AI_ANALYSIS="false"
ENABLE_EXPORT_PDF="true"
ENABLE_PUBLIC_SHARE="true"
